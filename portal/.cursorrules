    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root { 
            --bg-color: #050505; 
            --text-color: #e0e0e0; 
            --accent-red: #8b0000; 
            --accent-red-bright: #ff1a1a;
